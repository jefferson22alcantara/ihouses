# Production environment for docker-compose.prod.yml.
# This file lives ONLY on the server at /opt/ihouses/.env — it is never
# committed and is not overwritten by the deploy pipeline.

ENVIRONMENT=production
DEBUG=false

POSTGRES_USER=ihouses
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_RANDOM_PASSWORD
POSTGRES_DB=ihouses
DATABASE_URL=postgresql+asyncpg://ihouses:CHANGE_ME_TO_A_STRONG_RANDOM_PASSWORD@db:5432/ihouses

REDIS_URL=redis://redis:6379/0

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# 30s is fine while FUNDA_ENABLED=false (mock data, no external calls). If
# you flip FUNDA_ENABLED to true, raise this to at least 300 (5 min, the
# project's stated polling interval) — see the rate-limiting commitment in
# services/funda-client/NOTICE.md.
SCRAPE_INTERVAL_SECONDS=30

# See services/funda-client/NOTICE.md before enabling: pyfunda is AGPL-3.0
# and its use may violate Funda's Terms of Service. This was explicitly
# accepted for this project on 2026-07-17 — flip to true to go live, and
# raise SCRAPE_INTERVAL_SECONDS above when you do.
FUNDA_ENABLED=false
FUNDA_CLIENT_URL=http://funda-client:8000
